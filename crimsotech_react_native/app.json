{
  "expo": {
    "name": "Crimsotech",
    "slug": "crimsotech",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/crimsotechlogo.png",
    "scheme": "crimsotechreactnative",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.crimsonity.crimsotech",
      "infoPlist": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": ["crimsotechreactnative"]
          }
        ]
      }
    },
    "android": {
      "package": "com.crimsonity.crimsotech",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/crimsotechlogo.png",
        "backgroundColor": "#E6F4FE"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "usesCleartextTraffic": true,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "crimsotechreactnative",
              "host": "*"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store",
      "expo-web-browser",
      "expo-font",
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "owner": "nestyyy",
    "extra": {
      "eas": {
        "projectId": "e5ebb4fa-f758-4b0b-a72a-f78c2f88cbd9"
      }
    }
  }
}