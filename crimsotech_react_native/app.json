{
  "expo": {
    "name": "Crimsotech",
    "slug": "crimsotech",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/crimsotechlogo.png",
    "scheme": "crimsotechreactnative",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.crimsonity.crimsotech",
      "config": {
        "googleMapsApiKey": "AIzaSyBJD7F6025lQEecWMRqgIyViOv9Q9SeHKc"
      },
      "infoPlist": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "crimsotechreactnative"
            ]
          }
        ],
        "NSLocationWhenInUseUsageDescription": "Allow Crimsotech to use your location to pin delivery addresses.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Allow Crimsotech to use your location for delivery tracking."
      }
    },
    "android": {
      "package": "com.crimsonity.crimsotech",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/crimsotechlogo.png",
        "backgroundColor": "#E6F4FE"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "usesCleartextTraffic": true,
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyBJD7F6025lQEecWMRqgIyViOv9Q9SeHKc"
        }
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.INTERNET"
      ],
      
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "crimsotechreactnative",
              "host": "*"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
        
      ],
      "expo-secure-store",
      "expo-web-browser",
      "expo-font",
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Crimsotech to use your location to pin delivery addresses.",
          "locationWhenInUsePermission": "Allow Crimsotech to use your location for delivery tracking."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "bf7a5f8b-a7c1-4b9d-843d-6bcb371bab91"
      }
    },
    "owner": "nesty2"
  }
}
